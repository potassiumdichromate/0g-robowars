# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://your-game-domain.com

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/robowars

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_64_random_bytes
JWT_EXPIRES_IN=24h

# ── 0G Storage — MAINNET (chain ID 16661) ──────────────────────────────────────
# Mainnet EVM RPC — anchors all storage transactions on the 0G chain
ZG_RPC_URL=https://evmrpc.0g.ai

# Turbo indexer — fastest finality, recommended for production
ZG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# Private key of the wallet that pays for storage submissions (NEVER expose)
ZG_PRIVATE_KEY=0x_your_storage_wallet_private_key

# Mainnet requires ≥3 replicas for production durability guarantees
ZG_EXPECTED_REPLICAS=3

# Mainnet Flow contract (anchors Merkle roots on-chain)
# Reference: https://docs.0g.ai/developer-hub/mainnet/mainnet-overview
ZG_FLOW_CONTRACT=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526

# ── 0G DA — MAINNET ────────────────────────────────────────────────────────────
# DA disperser gRPC endpoint — mainnet DA network
ZG_DA_DISPERSER=disperser.0g.ai:51001

# TLS is required on mainnet DA
ZG_DA_TLS=true

# Max ms to wait for DA FINALIZED status (BLS aggregation can take 2–5 min on mainnet)
ZG_DA_POLL_TIMEOUT_MS=300000
ZG_DA_POLL_INTERVAL_MS=10000

# Mainnet DA payment contract — deposit 0G tokens here before submitting blobs
# Reference: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/router/account/deposits
ZG_DA_PAYMENT_CONTRACT=0xA3b15Bd2aD18BFB6b5f92D8AA9F444Dd59d1cE32

# ── 0G Compute Network — MAINNET ───────────────────────────────────────────────
# Create at: pc.0g.ai → Dashboard → API Keys (inference permission)
# Fund wallet at: pc.0g.ai → Dashboard → Deposit
ZG_COMPUTE_API_KEY=sk-your_compute_api_key

# Mainnet Compute Router
ZG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1

# Model: 131K context window, native JSON mode — optimal for structured validation
ZG_COMPUTE_MODEL=zai-org/GLM-5-FP8

# Synchronous TEE attestation check on every inference call (strongly recommended)
ZG_COMPUTE_VERIFY_TEE=true

# Independent EIP-191 signature verification against on-chain TEE key (+~500ms)
ZG_COMPUTE_INDEPENDENT_VERIFY=true

# Routing strategy: "latency" | "price" | "" (auto round-robin)
ZG_COMPUTE_ROUTING=latency

# Request timeout in milliseconds
ZG_COMPUTE_TIMEOUT_MS=30000

# Minimum confidence score — saves below this threshold are flagged SUSPICIOUS
ZG_COMPUTE_MIN_CONFIDENCE=0.70

# 0G Service Registry contract address (for independent TEE key lookup)
# Set when officially published on mainnet docs
# ZG_SERVICE_REGISTRY_ADDRESS=0x...

# ── File Limits ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
NONCE_EXPIRY_MS=300000
