# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://your-game-domain.com

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/robowars

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_64_random_bytes
JWT_EXPIRES_IN=24h

# ── 0G Storage — MAINNET (chain ID 16661) ──────────────────────────────────────
# Mainnet EVM RPC — confirmed in official mainnet overview docs
ZG_RPC_URL=https://evmrpc.0g.ai

# Turbo indexer — confirmed in official mainnet overview docs
ZG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# Primary key — used for auth/compute on-chain lookups and as fallback signer.
# Keep this as a cold wallet with minimal on-chain permissions.
ZG_PRIVATE_KEY=0x_your_primary_wallet_private_key

# ── Key separation (recommended for production) ─────────────────────────────
# Dedicated storage signer — signs 0G Flow contract txs for file uploads ONLY.
# Use a separate hot wallet funded only with enough 0G tokens for storage gas.
# If not set, falls back to ZG_PRIVATE_KEY (backward-compatible, not recommended).
#
# Security benefit: a compromised ZG_STORAGE_PRIVATE_KEY can only pollute
# storage. It cannot be used for auth, Compute, or any non-storage operation.
# Blast radius is contained.
ZG_STORAGE_PRIVATE_KEY=0x_your_dedicated_storage_wallet_private_key

# Mainnet requires ≥3 replicas for durability
ZG_EXPECTED_REPLICAS=3

# Mainnet Flow contract — confirmed: https://docs.0g.ai/developer-hub/mainnet/mainnet-overview
ZG_FLOW_CONTRACT=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526

# ── 0G DA — ⚠️ TESTNET ONLY (Galileo, chain ID 16602) ─────────────────────────
# STATUS: As of May 2026, 0G DA does NOT have a published mainnet disperser
# endpoint or mainnet contract addresses in official docs.
# DA is in active development. The testnet (Galileo) is live and usable.
# Official testnet DA contract (DAEntrance): 0xE75A073dA5bb7b0eC622170Fd268f35E675a957B
#
# Once 0G Labs publishes mainnet DA endpoints, update these values.
# Track: https://docs.0g.ai/developer-hub/building-on-0g/da-integration
# Or ask in: https://discord.gg/0glabs

ZG_DA_DISPERSER=disperser-testnet.0g.ai:51001
ZG_DA_TLS=false
ZG_DA_POLL_TIMEOUT_MS=120000
ZG_DA_POLL_INTERVAL_MS=5000

# Testnet DA entrance contract (Galileo only)
ZG_DA_ENTRANCE_CONTRACT=0xE75A073dA5bb7b0eC622170Fd268f35E675a957B

# ── 0G Compute Network — MAINNET ───────────────────────────────────────────────
# Compute Router is mainnet — confirmed: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/router/quickstart
# Create API key: pc.0g.ai → Dashboard → API Keys
# Deposit 0G tokens for billing: pc.0g.ai → Dashboard → Deposit
# Compute payment contract (mainnet): 0xA3b15Bd2aD18BFB6b5f92D8AA9F444Dd59d1cE32
ZG_COMPUTE_API_KEY=sk-your_compute_api_key
ZG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
ZG_COMPUTE_MODEL=zai-org/GLM-5-FP8
ZG_COMPUTE_VERIFY_TEE=true
ZG_COMPUTE_INDEPENDENT_VERIFY=true
ZG_COMPUTE_ROUTING=latency
ZG_COMPUTE_TIMEOUT_MS=30000
ZG_COMPUTE_MIN_CONFIDENCE=0.70

# ── File Limits ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
NONCE_EXPIRY_MS=300000
